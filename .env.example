# =============================================================
# Radar Diario de IA - Configuracao de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env
# =============================================================

# --- Gemini API (obrigatorio) ---
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# --- Email (obrigatorio para receber relatorios) ---
# Use uma "Senha de App" do Gmail:
# https://myaccount.google.com/apppasswords
EMAIL_SENDER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_aqui
EMAIL_RECIPIENT=cebaldez@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=radar2026

# --- Whisper (opcional - para transcricao local) ---
# Modelos: tiny, base, small, medium, large-v3
# Quanto maior, mais preciso, mas mais lento e pesado
WHISPER_MODEL=base

# --- Horario do relatorio diario ---
# Formato cron (padrao: 22:00 horario Dallas/CST = 04:00 UTC)
CRON_SCHEDULE=0 4 * * *

# --- Timezone ---
TZ=America/Chicago
